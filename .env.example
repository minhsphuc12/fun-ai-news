# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: anthropic | gemini  (default: anthropic)
LLM_PROVIDER=anthropic

# ── API Keys — add only the one you need ─────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key_here

# ── Pipeline options ──────────────────────────────────────────────────────────
# Optional: how many news items to fetch (default 5)
NEWS_COUNT=5
# Tone: sarcastic | absurdist | well_actually (default: sarcastic)
POST_TONE=sarcastic
